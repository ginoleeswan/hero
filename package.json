{
  "name": "hero",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:ci": "jest --ci",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json}\"",
    "eas-build-pre-install": "corepack enable && yarn set version 4"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/righteous": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@supabase/supabase-js": "^2.101.1",
    "base64-arraybuffer": "^1.0.2",
    "dotenv": "^17.4.1",
    "expo": "~55.0.12",
    "expo-constants": "~55.0.12",
    "expo-dev-client": "^55.0.23",
    "expo-dev-menu": "^55.0.20",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.13",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.12",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.11",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.14",
    "expo-updates": "~55.0.19",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-circular-progress": "^1.4.1",
    "react-native-figma-squircle": "^0.4.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-progress": "^5.0.1",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-touchable-scale": "^2.2.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.5.2",
    "@types/react": "~19.2.10",
    "@types/sharp": "^0.32.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.14",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-dev-client",
        "expo-dev-menu",
        "expo-dev-launcher"
      ]
    }
  },
  "private": true,
  "packageManager": "yarn@4.13.0",
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-reanimated)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleNameMapper": {
      "^react-native-reanimated/mock$": "<rootDir>/__mocks__/react-native-reanimated-mock-shim.js"
    }
  }
}
